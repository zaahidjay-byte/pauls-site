---
import Base from '../layouts/Base.astro';
import { equipment } from '../data/equipment';

// Values must match the backend EventType enum
const eventTypes = [
  { value: 'wedding', label: 'Wedding' },
  { value: 'birthday', label: 'Birthday' },
  { value: 'corporate', label: 'Corporate Event' },
  { value: 'private', label: 'Private Function' },
  { value: 'school', label: 'School Event' },
  { value: 'festival', label: 'Festival' },
  { value: 'market', label: 'Market' },
  { value: 'expo', label: 'Expo' },
  { value: 'popup', label: 'Pop-up' },
  { value: 'community', label: 'Community Event' },
  { value: 'other', label: 'Other' },
];

const venueTypes = ['Indoor', 'Outdoor', 'Both'];
---

<Base title="Get a Quote" description="Request a quote from Paul's Homemade Events. Tell us about your event and we'll send your formal quote.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl font-bold text-center mb-2">Get a Quote</h1>
    <p class="text-center text-pauls-dark-blue/60 mb-12">
      Fill in the details below and we'll send your formal quote.
    </p>

    <form id="quote-form" class="space-y-8" novalidate>
      <!-- Your Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-blue rounded-full"></span>
          Your Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label for="name" class="block text-sm font-medium mb-1">Name *</label>
            <input type="text" id="name" name="name" required maxlength="255" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="name"></p>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1">Email</label>
            <input type="email" id="email" name="email" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="email"></p>
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1">Phone</label>
            <input type="tel" id="phone" name="phone" maxlength="20" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="phone"></p>
          </div>
          <p class="sm:col-span-2 text-xs text-pauls-dark-blue/50 -mt-2">Give us at least one way to reach you — email or phone.</p>
        </div>
      </fieldset>

      <!-- Event Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-pink rounded-full"></span>
          Event Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="event-type" class="block text-sm font-medium mb-1">Event Type</label>
            <select id="event-type" name="event_type" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none bg-white">
              {eventTypes.map(({ value, label }) => <option value={value}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="event-date" class="block text-sm font-medium mb-1">Event Date *</label>
            <input type="date" id="event-date" name="event_date" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="event_date"></p>
          </div>
          <div>
            <label for="start-time" class="block text-sm font-medium mb-1">Start Time</label>
            <input type="time" id="start-time" name="start_time" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="end-time" class="block text-sm font-medium mb-1">End Time</label>
            <input type="time" id="end-time" name="end_time" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="headcount" class="block text-sm font-medium mb-1">Number of Guests</label>
            <input type="number" id="headcount" name="headcount" min="1" inputmode="numeric" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="headcount"></p>
          </div>
        </div>
      </fieldset>

      <!-- Venue Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-blue rounded-full"></span>
          Venue Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="venue" class="block text-sm font-medium mb-1">Venue Name</label>
            <input type="text" id="venue" name="venue" maxlength="255" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="venue-type" class="block text-sm font-medium mb-1">Venue Type</label>
            <select id="venue-type" name="venue_type" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none bg-white">
              <option value="">Select...</option>
              {venueTypes.map((v) => <option value={v}>{v}</option>)}
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="address" class="block text-sm font-medium mb-1">Event Address</label>
            <input type="text" id="address" name="address" maxlength="512" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            <p class="text-xs text-pauls-dark-blue/50 mt-1">Full street address — for travel calculation in your quote.</p>
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="address"></p>
          </div>
        </div>
      </fieldset>

      <!-- Equipment -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-pink rounded-full"></span>
          Equipment
        </legend>
        <p class="text-sm text-pauls-dark-blue/60 mb-4">Pick one or more setups — we'll confirm the best fit in your quote.</p>
        <div class="grid sm:grid-cols-2 gap-3">
          {equipment.map(({ slug, name, specs, icon, needsUnits, needsBains }) => (
            <label class="equipment-card relative flex items-start gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer transition-colors has-[:checked]:border-pauls-blue has-[:checked]:bg-pauls-light-blue/30">
              <input
                type="checkbox"
                name="equipment"
                value={slug}
                data-needs-units={needsUnits ? '1' : ''}
                data-needs-bains={needsBains ? '1' : ''}
                class="mt-1 accent-pauls-blue"
              />
              <span>
                <span class="block font-bold text-sm">{icon} {name}</span>
                <span class="block text-xs text-pauls-dark-blue/50 mt-1">{specs.join(' · ')}</span>
              </span>
            </label>
          ))}
        </div>
        <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="equipment"></p>

        <!-- Conditional steppers -->
        <div class="grid sm:grid-cols-2 gap-4 mt-4">
          <div id="units-wrap" class="hidden">
            <label for="units" class="block text-sm font-medium mb-1">Mini-pint units</label>
            <div class="flex items-center gap-2">
              <button type="button" data-step="units" data-dir="-1" class="w-10 h-10 rounded-lg border border-gray-300 font-bold text-lg hover:bg-gray-50" aria-label="Fewer units">&minus;</button>
              <input type="number" id="units" name="units" min="0" max="10000" inputmode="numeric" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-center focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
              <button type="button" data-step="units" data-dir="1" class="w-10 h-10 rounded-lg border border-gray-300 font-bold text-lg hover:bg-gray-50" aria-label="More units">+</button>
            </div>
            <p id="units-hint" class="text-xs text-pauls-dark-blue/50 mt-1">Minimum order: 40 units.</p>
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="units"></p>
          </div>
          <div id="bains-wrap" class="hidden">
            <label for="bains" class="block text-sm font-medium mb-1">Bains (flavour tubs)</label>
            <div class="flex items-center gap-2">
              <button type="button" data-step="bains" data-dir="-1" class="w-10 h-10 rounded-lg border border-gray-300 font-bold text-lg hover:bg-gray-50" aria-label="Fewer bains">&minus;</button>
              <input type="number" id="bains" name="bains" min="0" max="50" inputmode="numeric" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-center focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
              <button type="button" data-step="bains" data-dir="1" class="w-10 h-10 rounded-lg border border-gray-300 font-bold text-lg hover:bg-gray-50" aria-label="More bains">+</button>
            </div>
            <p class="text-xs text-pauls-dark-blue/50 mt-1">Minimum: 4 bains (~28–32 scoops each).</p>
            <p class="field-error hidden text-sm text-red-600 mt-1" data-error-for="bains"></p>
          </div>
        </div>
      </fieldset>

      <!-- Extras -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-blue rounded-full"></span>
          Extras
        </legend>
        <div class="space-y-4">
          <div>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="branding-toggle" class="accent-pauls-pink rounded" />
              <span class="text-sm font-medium">I'm interested in custom branding</span>
            </label>
            <div id="branding-wrap" class="hidden mt-2">
              <textarea id="custom-branding" name="custom_branding" rows="2" placeholder="Tell us what you have in mind — your logo, colours, brand identity on the setup..." class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none resize-y"></textarea>
            </div>
          </div>
          <div>
            <label for="special-requests" class="block text-sm font-medium mb-1">Special Requests</label>
            <textarea id="special-requests" name="special_requests" rows="3" placeholder="Flavour wishes, toppings, accessibility notes, anything else we should know..." class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none resize-y"></textarea>
          </div>
        </div>
      </fieldset>

      <!-- Honeypot — must stay empty -->
      <div class="absolute -left-[9999px] top-auto w-px h-px overflow-hidden" aria-hidden="true">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <p id="form-error" class="hidden text-center text-sm font-medium text-red-600"></p>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-pauls-blue text-white py-3.5 rounded-full font-bold text-lg hover:bg-blue-700 transition-colors shadow-lg disabled:opacity-60"
      >
        Request My Quote
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="form-success" class="hidden text-center py-16">
      <div class="text-5xl mb-4">&#127846;</div>
      <h2 class="text-2xl font-bold mb-2">Thanks — your quote request is in.</h2>
      <p class="text-pauls-dark-blue/60 mb-6">We'll send your formal quote shortly.</p>
      <a href="/" class="text-pauls-blue font-bold hover:underline">Back to Home</a>
    </div>
  </section>
</Base>

<script>
  const ENQUIRY_URL = 'https://admin.paulshomemade.co.za/enquiry';
  const UNITS_MIN = 40;
  const BAINS_MIN = 4;

  const form = document.getElementById('quote-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const formError = document.getElementById('form-error') as HTMLParagraphElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const unitsWrap = document.getElementById('units-wrap')!;
  const bainsWrap = document.getElementById('bains-wrap')!;
  const unitsInput = document.getElementById('units') as HTMLInputElement;
  const bainsInput = document.getElementById('bains') as HTMLInputElement;
  const unitsHint = document.getElementById('units-hint')!;

  const equipmentBoxes = Array.from(
    form.querySelectorAll<HTMLInputElement>('input[name="equipment"]')
  );

  // --- conditional steppers ---
  function phicycleSelected() {
    return equipmentBoxes.some((b) => b.checked && b.value === 'phicycle');
  }
  function unitsMin() {
    // 40-unit minimum applies to the Phicycle; countertop-freezer minimum not yet confirmed
    return phicycleSelected() ? UNITS_MIN : 1;
  }
  function refreshSteppers() {
    const showUnits = equipmentBoxes.some((b) => b.checked && b.dataset.needsUnits);
    const showBains = equipmentBoxes.some((b) => b.checked && b.dataset.needsBains);
    unitsWrap.classList.toggle('hidden', !showUnits);
    bainsWrap.classList.toggle('hidden', !showBains);
    if (showUnits) {
      unitsInput.min = String(unitsMin());
      unitsHint.classList.toggle('hidden', !phicycleSelected());
      if (!unitsInput.value && phicycleSelected()) unitsInput.value = String(UNITS_MIN);
    } else {
      unitsInput.value = '';
    }
    if (showBains) {
      bainsInput.min = String(BAINS_MIN);
      if (!bainsInput.value) bainsInput.value = String(BAINS_MIN);
    } else {
      bainsInput.value = '';
    }
  }
  equipmentBoxes.forEach((b) => b.addEventListener('change', refreshSteppers));

  // stepper +/- buttons
  form.querySelectorAll<HTMLButtonElement>('button[data-step]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.dataset.step === 'units' ? unitsInput : bainsInput;
      const min = btn.dataset.step === 'units' ? unitsMin() : BAINS_MIN;
      const max = Number(input.max || 10000);
      const cur = Number(input.value || 0);
      const next = cur + Number(btn.dataset.dir);
      input.value = String(Math.min(max, Math.max(min, next)));
    });
  });

  // custom branding reveal
  const brandingToggle = document.getElementById('branding-toggle') as HTMLInputElement;
  const brandingWrap = document.getElementById('branding-wrap')!;
  const brandingText = document.getElementById('custom-branding') as HTMLTextAreaElement;
  brandingToggle.addEventListener('change', () => {
    brandingWrap.classList.toggle('hidden', !brandingToggle.checked);
    if (!brandingToggle.checked) brandingText.value = '';
  });

  // pre-select equipment from URL (?equipment=slug or comma-separated)
  const params = new URLSearchParams(window.location.search);
  const pre = params.get('equipment');
  if (pre) {
    const slugs = pre.split(',');
    equipmentBoxes.forEach((b) => {
      if (slugs.includes(b.value)) b.checked = true;
    });
    refreshSteppers();
  }

  // --- validation + submit ---
  function clearErrors() {
    formError.classList.add('hidden');
    form.querySelectorAll('.field-error').forEach((el) => {
      el.classList.add('hidden');
      el.textContent = '';
    });
  }
  function setFieldError(field: string, message: string) {
    const el = form.querySelector(`[data-error-for="${field}"]`);
    if (el) {
      el.textContent = message;
      el.classList.remove('hidden');
    } else {
      formError.textContent = message;
      formError.classList.remove('hidden');
    }
  }

  function validate(): boolean {
    let ok = true;
    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const phone = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();
    const eventDate = (form.elements.namedItem('event_date') as HTMLInputElement).value;

    if (!name) { setFieldError('name', 'Please tell us your name.'); ok = false; }
    if (!email && !phone) {
      setFieldError('email', 'Give us an email or a phone number so we can send your quote.');
      ok = false;
    }
    if (!eventDate) { setFieldError('event_date', 'Please pick your event date.'); ok = false; }

    if (!unitsWrap.classList.contains('hidden') && unitsInput.value) {
      const min = unitsMin();
      if (Number(unitsInput.value) < min && min === UNITS_MIN) {
        setFieldError('units', `The Phicycle has a minimum order of ${UNITS_MIN} units.`);
        ok = false;
      }
    }
    if (!bainsWrap.classList.contains('hidden') && bainsInput.value) {
      if (Number(bainsInput.value) < BAINS_MIN) {
        setFieldError('bains', `Scooping setups have a minimum of ${BAINS_MIN} bains.`);
        ok = false;
      }
    }
    return ok;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    if (!validate()) return;

    const val = (n: string) => {
      const el = form.elements.namedItem(n) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
      return el ? el.value.trim() : '';
    };
    const orNull = (s: string) => (s === '' ? null : s);
    const intOrNull = (s: string) => (s === '' ? null : parseInt(s, 10));

    const payload = {
      name: val('name'),
      email: orNull(val('email')),
      phone: orNull(val('phone')),
      event_type: val('event_type') || 'private',
      event_date: val('event_date'),
      start_time: orNull(val('start_time')),
      end_time: orNull(val('end_time')),
      headcount: intOrNull(val('headcount')),
      venue: orNull(val('venue')),
      venue_type: orNull(val('venue_type')),
      address: orNull(val('address')),
      equipment: equipmentBoxes.filter((b) => b.checked).map((b) => b.value),
      units: unitsWrap.classList.contains('hidden') ? null : intOrNull(unitsInput.value),
      bains: bainsWrap.classList.contains('hidden') ? null : intOrNull(bainsInput.value),
      custom_branding: brandingToggle.checked ? orNull(brandingText.value.trim()) || 'Interested — details to follow' : null,
      special_requests: orNull(val('special_requests')),
      website: val('website'), // honeypot
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    try {
      const res = await fetch(ENQUIRY_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.status === 201) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }

      if (res.status === 429) {
        formError.textContent = "You've sent a few requests in a row — please try again in a little while.";
        formError.classList.remove('hidden');
        return;
      }

      if (res.status === 422) {
        const body = await res.json().catch(() => null);
        const errors = body?.detail;
        if (Array.isArray(errors)) {
          for (const err of errors) {
            const field = Array.isArray(err.loc) ? String(err.loc[err.loc.length - 1]) : '';
            setFieldError(field, err.msg || 'Please check this field.');
          }
        } else {
          formError.textContent = 'Please check the highlighted fields and try again.';
          formError.classList.remove('hidden');
        }
        return;
      }

      formError.textContent = 'Something went wrong sending your request. Please try again, or WhatsApp us on 082 678 3697.';
      formError.classList.remove('hidden');
    } catch {
      formError.textContent = 'Something went wrong sending your request. Please try again, or WhatsApp us on 082 678 3697.';
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Request My Quote';
    }
  });
</script>
