---
import Base from '../layouts/Base.astro';

const eventTypes = ['Birthday', 'Corporate Event', 'Wedding/Celebration', 'Brand Activation', 'Private Function', 'Other'];
const setupOptions = ['Scooping Phicycle', 'Unit Phicycle', 'Scooping Cart', 'Not Sure'];
const venueTypes = ['Indoor', 'Outdoor', 'Both'];
const toppings = [
  'Rainbow Vermicelli Sprinkles',
  'Chocolate Vermicelli Sprinkles',
  'Crushed Peanuts',
  'Crushed Oreos',
  'Rainbow Hundreds & Thousands',
  'Mini Marshmallows',
  'Mini Smarties',
];
---

<Base title="Book Your Event" description="Book Paul's Homemade Ice Cream for your next event in Johannesburg. Fill in the form and we'll get back to you within 24 hours.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl font-bold text-center mb-2">Book Your Event</h1>
    <p class="text-center text-pauls-dark-blue/60 mb-12">
      Fill in the details below and we'll get back to you within 24 hours.
    </p>

    <form
      id="booking-form"
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="space-y-8"
    >
      <!-- Your Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-blue rounded-full"></span>
          Your Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium mb-1">Name *</label>
            <input type="text" id="name" name="name" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="surname" class="block text-sm font-medium mb-1">Surname *</label>
            <input type="text" id="surname" name="surname" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1">Phone *</label>
            <input type="tel" id="phone" name="phone" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1">Email *</label>
            <input type="email" id="email" name="email" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
        </div>
      </fieldset>

      <!-- Event Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-pink rounded-full"></span>
          Event Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="event-date" class="block text-sm font-medium mb-1">Event Date *</label>
            <input type="date" id="event-date" name="event_date" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="guests" class="block text-sm font-medium mb-1">Number of Guests *</label>
            <input type="number" id="guests" name="guests" min="1" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="start-time" class="block text-sm font-medium mb-1">Start Time *</label>
            <input type="time" id="start-time" name="start_time" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="end-time" class="block text-sm font-medium mb-1">End Time *</label>
            <input type="time" id="end-time" name="end_time" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label for="event-type" class="block text-sm font-medium mb-1">Event Type *</label>
            <select id="event-type" name="event_type" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none bg-white">
              <option value="">Select event type...</option>
              {eventTypes.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>
        </div>
      </fieldset>

      <!-- Venue Details -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-blue rounded-full"></span>
          Venue Details
        </legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="venue-name" class="block text-sm font-medium mb-1">Venue Name *</label>
            <input type="text" id="venue-name" name="venue_name" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="city" class="block text-sm font-medium mb-1">City / Area *</label>
            <input type="text" id="city" name="city" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label for="venue-address" class="block text-sm font-medium mb-1">Venue Address *</label>
            <input type="text" id="venue-address" name="venue_address" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="venue-type" class="block text-sm font-medium mb-1">Venue Type *</label>
            <select id="venue-type" name="venue_type" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none bg-white">
              <option value="">Select...</option>
              {venueTypes.map((v) => <option value={v}>{v}</option>)}
            </select>
          </div>
          <div>
            <label for="accessibility" class="block text-sm font-medium mb-1">Accessibility Notes</label>
            <input type="text" id="accessibility" name="accessibility_notes" placeholder="e.g. stairs, gravel path" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
        </div>
      </fieldset>

      <!-- Setup & Extras -->
      <fieldset>
        <legend class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="w-6 h-1 bg-pauls-pink rounded-full"></span>
          Setup & Extras
        </legend>
        <div class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="setup" class="block text-sm font-medium mb-1">Preferred Setup *</label>
              <select id="setup" name="preferred_setup" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none bg-white">
                <option value="">Select setup...</option>
                {setupOptions.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Electricity Available? *</label>
              <div class="flex gap-4 pt-2">
                {['Yes', 'No', 'Not Sure'].map((opt) => (
                  <label class="flex items-center gap-1.5 cursor-pointer">
                    <input type="radio" name="electricity" value={opt} required class="accent-pauls-blue" />
                    <span class="text-sm">{opt}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2">Toppings</label>
            <div class="flex flex-wrap gap-3">
              {toppings.map((t) => (
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="checkbox" name="toppings" value={t} class="accent-pauls-pink rounded" />
                  <span class="text-sm">{t}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Custom Branding?</label>
            <div class="flex gap-4 pt-1">
              {['Yes', 'No'].map((opt) => (
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="custom_branding" value={opt} class="accent-pauls-blue" />
                  <span class="text-sm">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label for="notes" class="block text-sm font-medium mb-1">Additional Notes</label>
            <textarea id="notes" name="additional_notes" rows="3" placeholder="Anything else we should know about your event..." class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none resize-y"></textarea>
          </div>
        </div>
      </fieldset>

      <button
        type="submit"
        class="w-full bg-pauls-blue text-white py-3.5 rounded-full font-bold text-lg hover:bg-blue-700 transition-colors shadow-lg"
      >
        Submit Booking Request
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="form-success" class="hidden text-center py-16">
      <div class="text-5xl mb-4">&#127846;</div>
      <h2 class="text-2xl font-bold mb-2">Thanks! We've got your booking request.</h2>
      <p class="text-pauls-dark-blue/60 mb-6">We'll be in touch within 24 hours to confirm your event details.</p>
      <a href="/" class="text-pauls-blue font-bold hover:underline">Back to Home</a>
    </div>
  </section>
</Base>

<script>
  // Pre-fill setup from URL params (when coming from /events CTA buttons)
  const params = new URLSearchParams(window.location.search);
  const setup = params.get('setup');
  if (setup) {
    const select = document.getElementById('setup') as HTMLSelectElement;
    if (select) {
      for (const option of select.options) {
        if (option.value === setup) {
          option.selected = true;
          break;
        }
      }
    }
  }

  // Handle form submission
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try again or email us directly at bookings@paulshomemade.co.za');
      }
    } catch {
      alert('Something went wrong. Please try again or email us directly at bookings@paulshomemade.co.za');
    }
  });
</script>
