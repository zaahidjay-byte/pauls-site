---
import Base from '../layouts/Base.astro';
import { equipment, customBrandingCopy } from '../data/equipment';

const toppings = [
  'Rainbow Vermicelli Sprinkles',
  'Chocolate Vermicelli Sprinkles',
  'Crushed Peanuts',
  'Crushed Oreos',
  'Rainbow Hundreds & Thousands',
  'Mini Marshmallows',
  'Mini Smarties',
];
---

<Base title="Events & Setups" description="Five ice cream setups for events in Johannesburg: the Phicycle, Scooping Freezer, Scooping Cart, the Tuk Tuk, and Countertop Freezer.">
  <!-- Hero -->
  <section class="bg-pauls-blue text-white py-20 md:py-28 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl mb-4">Your big day, scooped to perfection</h1>
      <p class="text-lg text-white/80">Five setups. One unforgettable ice cream experience.</p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-pauls-light-blue/40 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { icon: '/home-assets/how-it-works/1-enquire.png', title: 'Enquire', desc: 'Fill in our quote form with your event details' },
          { icon: '/home-assets/how-it-works/2-plan.png', title: 'We Plan', desc: 'We confirm flavours, setup type, and send a quote' },
          { icon: '/home-assets/how-it-works/3-setup.png', title: 'We Show Up', desc: 'Full setup 30 minutes before your event' },
          { icon: '/home-assets/how-it-works/4-celebrate.png', title: 'You Enjoy', desc: 'We serve, you celebrate — then we clean up' },
        ].map(({ icon, title, desc }) => (
          <div class="text-center">
            <img src={icon} alt={title} width="141" height="141" loading="lazy" class="w-[123px] h-[123px] md:w-[141px] md:h-[141px] mx-auto mb-3" />
            <h3 class="text-xl mb-1">{title}</h3>
            <p class="text-sm text-pauls-dark-blue/60">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Setups -->
  <section class="bg-pauls-light-blue/30 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="eyebrow">Equipment</p>
      <h2 class="text-3xl text-center mb-12">Our Setups</h2>
      <div class="space-y-10">
        {equipment.map(({ slug, name, tagline, blurb, specs, ideal, icon }) => (
          <article id={slug} class="bg-white rounded-2xl shadow-sm overflow-hidden md:flex scroll-mt-24">
            <!-- Photo slot — human will drop event photography into src/assets/photos/ -->
            <div class="md:w-2/5 bg-gradient-to-br from-pauls-blue to-pauls-dark-blue flex items-center justify-center text-7xl py-16 md:py-0">
              {icon}
            </div>
            <div class="p-8 md:w-3/5 flex flex-col">
              <h3 class="text-2xl text-pauls-dark-blue mb-1">{name}</h3>
              {tagline && <p class="text-sm font-bold text-pauls-pink mb-3">{tagline}</p>}
              <p class="text-pauls-dark-blue/70 text-sm leading-relaxed mb-4">{blurb}</p>
              <ul class="text-sm space-y-1 mb-4">
                {specs.map((d) => (
                  <li class="flex items-start gap-2">
                    <span class="text-pauls-blue mt-0.5">&#10003;</span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-auto">
                {ideal && (
                  <p class="text-xs text-pauls-dark-blue/50 mb-4">
                    <strong>Ideal for:</strong> {ideal}.
                  </p>
                )}
                <a
                  href={`/book?equipment=${slug}`}
                  class="inline-block text-center bg-pauls-blue text-white px-8 py-2.5 rounded-full font-bold text-sm hover:bg-blue-700 transition-colors"
                >
                  Get a quote
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-3xl mb-6">What's Included</h2>
        <ul class="space-y-3">
          {[
            'Full service team (setup, serving, cleanup)',
            '30-minute pre-event setup',
            'Cups, cones, and serviettes',
            'Optional toppings bar',
            'Custom branding option available',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-pauls-pink text-lg">&#10003;</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="text-3xl mb-6">Optional Toppings</h2>
        <div class="flex flex-wrap gap-2">
          {toppings.map((t) => (
            <span class="bg-pauls-light-blue/60 text-pauls-dark-blue px-3 py-1.5 rounded-full text-sm">{t}</span>
          ))}
        </div>
        <div class="mt-8">
          <h3 class="text-xl mb-2">Custom Branding</h3>
          <p class="text-sm text-pauls-dark-blue/60">{customBrandingCopy}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-pauls-light-blue/40 py-16 text-center">
    <blockquote class="max-w-2xl mx-auto px-4">
      <p class="text-xl italic text-pauls-dark-blue/80 mb-4">
        "Not only was the ice cream exceptional, but their team was punctual, professional, and so fun to have at our event!"
      </p>
      <footer class="font-bold text-pauls-blue">— George Georgiades</footer>
    </blockquote>
  </section>

  <!-- CTA -->
  <section class="bg-pauls-pink text-white py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl mb-4">Ready to book?</h2>
      <p class="text-white/80 mb-8">Tell us about your event and we'll handle the rest.</p>
      <a href="/book" class="bg-white text-pauls-pink px-8 py-3.5 rounded-full font-bold text-lg hover:bg-pauls-offwhite transition-colors shadow-lg">
        Get a Quote
      </a>
    </div>
  </section>
</Base>
