---
import Base from '../layouts/Base.astro';

const toppings = [
  'Rainbow Vermicelli Sprinkles',
  'Chocolate Vermicelli Sprinkles',
  'Crushed Peanuts',
  'Crushed Oreos',
  'Rainbow Hundreds & Thousands',
  'Mini Marshmallows',
  'Mini Smarties',
];

const setups = [
  {
    name: 'Scooping Phicycle',
    desc: 'Retro-inspired bicycle serving traditional scoops in cups and cones.',
    details: ['Minimum: 2 bains (~56 scoops)', 'Requires electricity'],
    ideal: 'Birthdays, small weddings, office celebrations, outdoor events, year-end functions, engagements, baby showers, bachelorette parties',
    slug: 'Scooping Phicycle',
  },
  {
    name: 'Unit Phicycle',
    desc: 'No-power-required freezer-style bicycle serving mini pints.',
    details: ['Minimum: 40 units', 'No electricity needed', 'Accommodates 200+ guests'],
    ideal: "Kids' birthdays, small spaces, outdoor gatherings, corporate functions, school events, sports days",
    slug: 'Unit Phicycle',
  },
  {
    name: 'Scooping Cart',
    desc: 'Sleek, compact cart with up to 6 bains for large events.',
    details: ['Minimum: 4 bains (~112 scoops)', 'Up to 6 bains (~168 scoops)', 'Serves 100–250 guests', 'Requires electricity'],
    ideal: 'Weddings, corporate events, festivals, bar/bat mitzvahs, brand activations, large celebrations',
    slug: 'Scooping Cart',
  },
];
---

<Base title="Events" description="Full-service ice cream catering for events in Johannesburg. Scooping Phicycle, Unit Phicycle, and Scooping Cart setups available.">
  <!-- Hero -->
  <section class="bg-pauls-blue text-white py-20 md:py-28 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">It's not a celebration without Paul's</h1>
      <p class="text-lg text-white/80">Event ice cream catering across Johannesburg and beyond</p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h2 class="text-3xl font-bold text-center mb-12">How It Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-5 gap-6 max-w-5xl mx-auto">
      {[
        { step: '1', title: 'Tell us about your event', desc: 'Fill in the booking form with your details' },
        { step: '2', title: "We'll get back to you", desc: 'Confirm flavours, setup, and send a quote' },
        { step: '3', title: 'We arrive early', desc: '30-minute pre-event setup at your venue' },
        { step: '4', title: 'We serve your guests', desc: 'Full-service scooping team at your event' },
        { step: '5', title: 'We clean up', desc: 'Pack down and leave your venue spotless' },
      ].map(({ step, title, desc }) => (
        <div class="text-center">
          <div class="w-10 h-10 rounded-full bg-pauls-pink text-white font-bold flex items-center justify-center mx-auto mb-3">
            {step}
          </div>
          <h3 class="font-bold text-sm mb-1">{title}</h3>
          <p class="text-xs text-pauls-dark-blue/60">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Service Tiers -->
  <section class="bg-pauls-light-pink py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Our Setups</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {setups.map(({ name, desc, details, ideal, slug }) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm flex flex-col">
            <h3 class="text-xl font-bold text-pauls-dark-blue mb-2">{name}</h3>
            <p class="text-pauls-dark-blue/60 text-sm mb-4">{desc}</p>
            <ul class="text-sm space-y-1 mb-4">
              {details.map((d) => (
                <li class="flex items-start gap-2">
                  <span class="text-pauls-blue mt-0.5">&#10003;</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
            <div class="mt-auto">
              <p class="text-xs text-pauls-dark-blue/50 mb-4">
                <strong>Ideal for:</strong> {ideal}
              </p>
              <a
                href={`/book?setup=${encodeURIComponent(slug)}`}
                class="block text-center bg-pauls-blue text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-blue-700 transition-colors"
              >
                Book the {name}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-3xl font-bold mb-6">What's Included</h2>
        <ul class="space-y-3">
          {[
            'Full service team (setup, serving, cleanup)',
            '30-minute pre-event setup',
            'Cups, cones, and serviettes',
            'Optional toppings bar',
            'Custom branding option available',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-pauls-pink text-lg">&#10003;</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="text-3xl font-bold mb-6">Optional Toppings</h2>
        <div class="flex flex-wrap gap-2">
          {toppings.map((t) => (
            <span class="bg-pauls-light-blue/60 text-pauls-dark-blue px-3 py-1.5 rounded-full text-sm">{t}</span>
          ))}
        </div>
        <div class="mt-8">
          <h3 class="font-bold mb-2">Custom Branding</h3>
          <p class="text-sm text-pauls-dark-blue/60">
            Branded wrapping available for corporate events and brand activations. Mention it in your booking and we'll discuss the options.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-pauls-light-blue/40 py-16 text-center">
    <blockquote class="max-w-2xl mx-auto px-4">
      <p class="text-xl italic text-pauls-dark-blue/80 mb-4">
        "Not only was the ice cream exceptional, but their team was punctual, professional, and so fun to have at our event!"
      </p>
      <footer class="font-bold text-pauls-blue">— George Georgiades</footer>
    </blockquote>
  </section>

  <!-- CTA -->
  <section class="bg-pauls-pink text-white py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-4">Ready to book?</h2>
      <p class="text-white/80 mb-8">Tell us about your event and we'll handle the rest.</p>
      <a href="/book" class="bg-white text-pauls-pink px-8 py-3.5 rounded-full font-bold text-lg hover:bg-pauls-offwhite transition-colors shadow-lg">
        Book Your Event
      </a>
    </div>
  </section>
</Base>
