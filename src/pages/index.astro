---
import Base from '../layouts/Base.astro';
import { equipment } from '../data/equipment';
// Sections cloned from the Paul's Homemade (.com) homepage — "Seriously good fun"
// down through the flavour carousel, Paul's Difference, booking CTA and reviews.
// Images are placeholders (in /home-assets) to be replaced with our own pictures.
import homeSections from '../partials/home-sections.html?raw';
---

<Base title="Home">
  <!-- Hero -->
  <section class="relative bg-pauls-blue text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-pauls-blue via-pauls-dark-blue to-pauls-blue opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 text-center">
      <h1 class="text-4xl md:text-6xl leading-tight mb-4">
        Your big day,<br />scooped to perfection
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">
        Full-service ice cream catering for weddings, birthdays, corporate events and everything in between — across Johannesburg and beyond.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/book" class="bg-pauls-pink text-white px-8 py-3.5 rounded-full font-bold text-lg hover:opacity-90 transition-opacity shadow-lg">
          Get a Quote
        </a>
        <a href="/events" class="border-2 border-white/40 text-white px-8 py-3.5 rounded-full font-bold text-lg hover:bg-white/10 transition-colors">
          See Our Setups
        </a>
      </div>
    </div>
  </section>

  <!-- Equipment overview -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="eyebrow">Equipment</p>
    <h2 class="text-3xl md:text-4xl text-center mb-4">What We Do</h2>
    <p class="text-center text-pauls-dark-blue/60 mb-12 max-w-xl mx-auto">Five ways to bring Paul's to your event</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {equipment.map(({ slug, name, blurb, icon }) => (
        <a href={`/events#${slug}`} class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="text-4xl mb-4">{icon}</div>
          <h3 class="text-xl mb-2 group-hover:text-pauls-blue transition-colors">{name}</h3>
          <p class="text-pauls-dark-blue/60 text-sm line-clamp-3">{blurb}</p>
        </a>
      ))}
      <a href="/book" class="group bg-pauls-blue text-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow text-center flex flex-col items-center justify-center">
        <div class="text-4xl mb-4">📝</div>
        <h3 class="text-xl mb-2">Not sure which?</h3>
        <p class="text-white/80 text-sm">Tell us about your event and we'll recommend the right setup in your quote.</p>
      </a>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-pauls-light-blue/40 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { icon: '/home-assets/how-it-works/1-enquire.png', title: 'Enquire', desc: 'Fill in our quote form with your event details' },
          { icon: '/home-assets/how-it-works/2-plan.png', title: 'We Plan', desc: 'We confirm flavours, setup type, and send a quote' },
          { icon: '/home-assets/how-it-works/3-setup.png', title: 'We Show Up', desc: 'Full setup 30 minutes before your event' },
          { icon: '/home-assets/how-it-works/4-celebrate.png', title: 'You Enjoy', desc: 'We serve, you celebrate — then we clean up' },
        ].map(({ icon, title, desc }) => (
          <div class="text-center">
            <img src={icon} alt={title} width="141" height="141" loading="lazy" class="w-[123px] h-[123px] md:w-[141px] md:h-[141px] mx-auto mb-3" />
            <h3 class="text-xl mb-1">{title}</h3>
            <p class="text-sm text-pauls-dark-blue/60">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Cloned .com homepage sections: Seriously good fun → carousel → difference → booking → reviews ===== -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@3.2.2/dist/css/splide-core.min.css" />
  <Fragment set:html={homeSections} />

  <!-- Splide carousel runtime + init (verbatim from the .com homepage) -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@splidejs/splide@3.2.2/dist/js/splide.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@splidejs/splide-extension-auto-scroll@0.5.3/dist/js/splide-extension-auto-scroll.min.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var splideElements = document.querySelectorAll('.splide');
      for (var i = 0; i < splideElements.length; i++) {
        new Splide(splideElements[i], {
          type: 'loop',
          autoWidth: true,
          height: 'auto',
          drag: 'free',
          arrows: false,
          pagination: false,
          label: 'Image Slider',
          reduceMotion: { speed: 0, rewindSpeed: 0, autoplay: 'pause' },
          autoScroll: { speed: 0.6, pauseOnHover: false, pauseOnFocus: false },
          breakpoints: {
            991: { autoScroll: { speed: 0.6, pauseOnHover: false, pauseOnFocus: false } },
            767: { autoScroll: { speed: 0.6, pauseOnHover: false, pauseOnFocus: false } }
          }
        }).mount(window.splide.Extensions);
      }
    });
  </script>

</Base>
