---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Paul's Homemade Ice Cream Events in Johannesburg. For event bookings or general enquiries.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl font-bold text-center mb-2">Scoop up a conversation</h1>
    <p class="text-center text-pauls-dark-blue/60 mb-16">We'd love to hear from you</p>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact info -->
      <div class="space-y-8">
        <div>
          <h2 class="font-bold text-lg mb-3">Event Bookings</h2>
          <p class="text-pauls-dark-blue/70 text-sm mb-2">Ready to book ice cream for your event?</p>
          <a href="mailto:bookings@paulshomemade.co.za" class="text-pauls-blue font-medium hover:underline">
            bookings@paulshomemade.co.za
          </a>
          <p class="mt-2">
            <a href="/book" class="text-sm text-pauls-pink font-bold hover:underline">Fill in the booking form &rarr;</a>
          </p>
        </div>

        <div>
          <h2 class="font-bold text-lg mb-3">General Enquiries</h2>
          <a href="mailto:info@paulshomemade.co.za" class="text-pauls-blue font-medium hover:underline">
            info@paulshomemade.co.za
          </a>
        </div>

        <div>
          <h2 class="font-bold text-lg mb-3">Location</h2>
          <p class="text-pauls-dark-blue/70">Johannesburg, South Africa</p>
        </div>

        <div>
          <h2 class="font-bold text-lg mb-3">Follow Us</h2>
          <div class="flex gap-4">
            <a href="#" class="text-pauls-dark-blue/60 hover:text-pauls-blue transition-colors" aria-label="Instagram">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="#" class="text-pauls-dark-blue/60 hover:text-pauls-blue transition-colors" aria-label="Facebook">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.126-5.864 10.126-11.854z"/></svg>
            </a>
            <a href="#" class="text-pauls-dark-blue/60 hover:text-pauls-blue transition-colors" aria-label="TikTok">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="font-bold text-lg mb-4">Send us a message</h2>
        <form
          id="contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-4"
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="block text-sm font-medium mb-1">Name *</label>
              <input type="text" id="contact-name" name="name" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            </div>
            <div>
              <label for="contact-surname" class="block text-sm font-medium mb-1">Surname *</label>
              <input type="text" id="contact-surname" name="surname" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
            </div>
          </div>
          <div>
            <label for="contact-phone" class="block text-sm font-medium mb-1">Phone *</label>
            <input type="tel" id="contact-phone" name="phone" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="contact-email" class="block text-sm font-medium mb-1">Email *</label>
            <input type="email" id="contact-email" name="email" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none" />
          </div>
          <div>
            <label for="contact-message" class="block text-sm font-medium mb-1">Message *</label>
            <textarea id="contact-message" name="message" rows="5" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 focus:ring-2 focus:ring-pauls-blue focus:border-transparent outline-none resize-y"></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-pauls-blue text-white py-3 rounded-full font-bold hover:bg-blue-700 transition-colors"
          >
            Send Message
          </button>
        </form>

        <div id="contact-success" class="hidden text-center py-8">
          <h3 class="text-xl font-bold mb-2">Message sent!</h3>
          <p class="text-pauls-dark-blue/60">We'll get back to you soon.</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('contact-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try emailing us directly.');
      }
    } catch {
      alert('Something went wrong. Please try emailing us directly.');
    }
  });
</script>
