---
import Base from '../layouts/Base.astro';
import { CONTACT_PHONE_DISPLAY, CONTACT_PHONE_TEL, CONTACT_WHATSAPP, INSTAGRAM_URL, INSTAGRAM_HANDLE } from '../data/equipment';
---

<Base title="Contact" description="Get in touch with Paul's Homemade Events in Johannesburg. Call or WhatsApp 061 407 3799, or request a quote online.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl font-bold text-center mb-2">Scoop up a conversation</h1>
    <p class="text-center text-pauls-dark-blue/60 mb-16">We'd love to hear from you</p>

    <div class="space-y-10">
      <!-- Phone / WhatsApp -->
      <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
        <h2 class="font-bold text-lg mb-2">Call or WhatsApp</h2>
        <p class="text-2xl font-bold text-pauls-blue mb-4">
          <a href={`tel:${CONTACT_PHONE_TEL}`} class="hover:underline">{CONTACT_PHONE_DISPLAY}</a>
        </p>
        <a
          href={CONTACT_WHATSAPP}
          target="_blank"
          rel="noopener"
          class="inline-block bg-pauls-blue text-white px-8 py-3 rounded-full font-bold hover:bg-blue-700 transition-colors"
        >
          Message us on WhatsApp
        </a>
      </div>

      <!-- Instagram -->
      <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
        <h2 class="font-bold text-lg mb-2">Follow Us</h2>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-pauls-blue font-bold hover:underline"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          {INSTAGRAM_HANDLE}
        </a>
      </div>

      <!-- Quote CTA -->
      <div class="bg-pauls-blue text-white rounded-2xl p-8 text-center">
        <h2 class="font-bold text-xl mb-2">Planning an event?</h2>
        <p class="text-white/80 mb-6">Tell us the details and we'll send you a formal quote.</p>
        <a href="/book" class="inline-block bg-pauls-pink text-white px-8 py-3 rounded-full font-bold hover:opacity-90 transition-opacity">
          Get a Quote
        </a>
      </div>

      <p class="text-center text-sm text-pauls-dark-blue/50">Johannesburg, South Africa</p>
    </div>
  </section>
</Base>
