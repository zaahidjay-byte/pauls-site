---
import Base from '../layouts/Base.astro';
import { flavourCategories } from '../data/flavours';
---

<Base title="Flavours" description="Explore 30+ handcrafted ice cream flavours from Paul's Homemade — classic, vegan, health-conscious, and fan favourites.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl text-center mb-4">Our Flavours</h1>
    <p class="text-center text-pauls-dark-blue/60 max-w-xl mx-auto mb-4">
      30+ handcrafted flavours — from South African classics to vegan sorbets.
    </p>
    <p class="text-center text-sm text-pauls-dark-blue/40 max-w-lg mx-auto mb-16">
      Flavour availability varies by event. We'll confirm your selection during booking.
    </p>

    {flavourCategories.map((category) => (
      <div class="mb-16 last:mb-0">
        <h2 class="text-2xl mb-6 flex items-center gap-2">
          <span class="w-8 h-1 bg-pauls-pink rounded-full"></span>
          {category.name}
          <span class="text-sm font-normal text-pauls-dark-blue/40">({category.flavours.length})</span>
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {category.flavours.map((flavour) => (
            <div class="bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
              <h3 class="text-pauls-dark-blue mb-1">{flavour.name}</h3>
              <p class="text-sm text-pauls-dark-blue/60">{flavour.description}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- CTA -->
  <section class="bg-pauls-light-blue/40 py-12 text-center">
    <h2 class="text-2xl mb-3">Can't decide? Let us help.</h2>
    <p class="text-pauls-dark-blue/60 mb-6">Tell us about your event and we'll recommend the perfect selection.</p>
    <a href="/book" class="bg-pauls-blue text-white px-8 py-3 rounded-full font-bold hover:bg-blue-700 transition-colors">
      Book Your Event
    </a>
  </section>
</Base>
