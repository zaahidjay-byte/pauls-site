---
// Shared Webflow navbar (cloned from the flavours page) used site-wide.
// Raw HTML partial is injected verbatim so the Webflow markup/SVG is untouched.
import navbarRaw from '../partials/navbar.html?raw';

// Highlight the link matching the current route (Webflow's w--current state).
// Hrefs are trailing-slash to match Webflow's runtime current-link detection.
let path = Astro.url.pathname;
if (path !== '/' && !path.endsWith('/')) path += '/';
const escaped = path.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

let nav = navbarRaw
  .replace(/ aria-current="page"/g, '')
  .replace(/ w--current/g, '');

nav = nav.replace(
  new RegExp(`(<a href="${escaped}" )class="header-links w-nav-link"`),
  '$1aria-current="page" class="header-links w-nav-link w--current"',
);
---

<Fragment set:html={nav} />
