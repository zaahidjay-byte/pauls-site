---
// Footer styled to match the Paul's Homemade (.com) footer FORMAT — colours, fonts,
// layout via the shared Webflow classes — but populated with OUR information.
import { CONTACT_EMAIL, CONTACT_PHONE_DISPLAY, CONTACT_PHONE_TEL, CONTACT_WHATSAPP, INSTAGRAM_URL } from '../data/equipment';

const year = new Date().getFullYear();
---

<section class="section">
  <div class="w-layout-blockcontainer container footer w-container">
    <div class="w-layout-grid footer-grid">
      <div class="div downwards bottom-padding">
        <p class="navigation">Navigation</p>
        <a href="/" class="navigation-links">Home</a>
        <a href="/story/" class="navigation-links">Story</a>
        <a href="/flavours/" class="navigation-links">Flavours</a>
        <a href="/events/" class="navigation-links">Events</a>
      </div>

      <div class="div downwards">
        <p class="navigation">Quick</p>
        <a href="/book/" class="navigation-links">Get a Quote</a>
        <a href="/contact/" class="navigation-links">Contact</a>
        <a href="/flavours/" class="navigation-links">Our Flavours</a>
      </div>

      <div class="div downwards">
        <p class="navigation">Get in Touch</p>
        <a href={`tel:${CONTACT_PHONE_TEL}`} class="navigation-links">{CONTACT_PHONE_DISPLAY}</a>
        <a href={CONTACT_WHATSAPP} target="_blank" rel="noopener" class="navigation-links">WhatsApp</a>
        <a href={`mailto:${CONTACT_EMAIL}`} class="navigation-links">{CONTACT_EMAIL}</a>
      </div>

      <div class="div downwards">
        <p class="navigation">Visit</p>
        <a class="navigation-links">Johannesburg, South Africa</a>
        <a class="navigation-links">Events by appointment</a>
      </div>

      <div class="div footer-icon">
        <img src="/logo-badge.webp" loading="lazy" alt="Paul's Homemade" width="120" />
      </div>
    </div>

    <div class="w-layout-grid _2-column top-border">
      <div class="div middle-left">
        <div class="copyright">© {year} Paul's Homemade Events — Johannesburg. An official Paul's Homemade franchise — events division.</div>
      </div>
      <div class="div middle-right">
        <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="socials">Instagram</a>
      </div>
    </div>
  </div>
</section>
