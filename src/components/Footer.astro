---
import { CONTACT_EMAIL, CONTACT_PHONE_DISPLAY, CONTACT_PHONE_TEL, CONTACT_WHATSAPP, INSTAGRAM_URL, INSTAGRAM_HANDLE } from '../data/equipment';

const year = new Date().getFullYear();
---

<footer class="bg-pauls-dark-blue text-white/80 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <img src="/logo-badge.webp" alt="Paul's Homemade" class="h-12 w-12 rounded-full mb-3" />
        <p class="text-sm">Event ice cream catering across Johannesburg and beyond.</p>
        <p class="text-sm mt-3 text-white/60">An official Paul's Homemade franchise — events division.</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/events" class="hover:text-white transition-colors">Events & Setups</a></li>
          <li><a href="/flavours" class="hover:text-white transition-colors">Flavours</a></li>
          <li><a href="/book" class="hover:text-white transition-colors">Get a Quote</a></li>
          <li><a href="/story" class="hover:text-white transition-colors">Our Story</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white mb-3">Get in Touch</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`tel:${CONTACT_PHONE_TEL}`} class="hover:text-white transition-colors">{CONTACT_PHONE_DISPLAY}</a>
            <span class="text-white/50"> · </span>
            <a href={CONTACT_WHATSAPP} class="hover:text-white transition-colors" rel="noopener" target="_blank">WhatsApp</a>
          </li>
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-white transition-colors">{CONTACT_EMAIL}</a>
          </li>
          <li>Johannesburg, South Africa</li>
        </ul>
        <div class="flex gap-4 mt-4">
          <a href={INSTAGRAM_URL} aria-label={`Instagram ${INSTAGRAM_HANDLE}`} class="hover:text-white transition-colors" rel="noopener" target="_blank">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/20 mt-8 pt-6 text-center text-sm text-white/50">
      &copy; {year} Paul's Homemade Events — Johannesburg. An official Paul's Homemade franchise — events division.
    </div>
  </div>
</footer>
