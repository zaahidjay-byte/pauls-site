---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Book Paul's Homemade Ice Cream for your next event in Johannesburg. Full-service ice cream catering for weddings, birthdays, corporate events & more." } = Astro.props;
const fullTitle = `${title} | Paul's Homemade Ice Cream Events — Johannesburg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_ZA" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Paul's Homemade Ice Cream Events",
      "description": description,
      "url": "https://paulshomemade.co.za",
      "areaServed": { "@type": "City", "name": "Johannesburg" },
      "serviceType": "Event Ice Cream Catering",
      "email": "bookings@paulshomemade.co.za",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Johannesburg",
        "addressCountry": "ZA"
      }
    })} />
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Mobile sticky Book Now CTA -->
    <a
      href="/book"
      class="fixed bottom-4 left-4 right-4 z-50 md:hidden bg-pauls-pink text-white text-center font-bold py-3 rounded-full shadow-lg hover:bg-pink-500 transition-colors"
    >
      Book Your Event
    </a>
  </body>
</html>
