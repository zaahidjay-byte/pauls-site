---
import '../styles/global.css';
// Webflow theme imported AFTER Tailwind so its base element styles (heading sizes,
// etc.) win over Tailwind Preflight on the cloned Webflow sections. Tailwind utility
// classes (text-4xl, …) still win on our own pages via higher specificity.
import '../styles/webflow-theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_PHONE_TEL } from '../data/equipment';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Book Paul's Homemade Ice Cream for your next event in Johannesburg. Full-service ice cream catering for weddings, birthdays, corporate events & more." } = Astro.props;
const fullTitle = `${title} | Paul's Homemade Events — Johannesburg`;
const ogImage = new URL('/og-image.jpg', Astro.site ?? 'https://paulshomemade.co.za').href;
---

<!doctype html>
<html lang="en" data-wf-domain="paulshomemade.com" data-wf-page="697c7aa0644b0ff8d49a0782" data-wf-site="697c753df5739d5c83969f83">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Webflow theme (shared navbar styling, site-wide) + brand fonts -->
    <link rel="preconnect" href="https://cdn.prod.website-files.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://use.typekit.net/uei3rav.css" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Paul's Homemade Events",
      "description": description,
      "url": "https://paulshomemade.co.za",
      "areaServed": { "@type": "City", "name": "Johannesburg" },
      "serviceType": "Event Ice Cream Catering",
      "telephone": CONTACT_PHONE_TEL,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Johannesburg",
        "addressCountry": "ZA"
      }
    })} />
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Mobile sticky Book Now CTA -->
    <a
      href="/book"
      class="fixed bottom-4 left-4 right-4 z-50 md:hidden bg-pauls-pink text-white text-center font-bold py-3 rounded-full shadow-lg hover:opacity-90 transition-opacity"
    >
      Get a Quote
    </a>

    <!-- Webflow runtime (powers the shared navbar's mobile menu), loaded site-wide -->
    <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=697c753df5739d5c83969f83" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="/wf/js/webflow.schunk.36b8fb49256177c8.js" type="text/javascript"></script>
    <script src="/wf/js/webflow.schunk.2e25d4bd27e0b7b5.js" type="text/javascript"></script>
    <script src="/wf/js/webflow.schunk.24a644cf90d53fbd.js" type="text/javascript"></script>
    <script src="/wf/js/webflow.schunk.9dfb96661114d3db.js" type="text/javascript"></script>
    <script src="/wf/js/webflow.86995cce.4855fe74e36bc6da.js" type="text/javascript"></script>
  </body>
</html>
